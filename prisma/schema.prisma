generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  college   String
  password  String
  role        String   @default("member")
  foodScans   Int      @default(0)
  kitReceived Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamId       String?
  team         Team?    @relation("TeamMembers", fields: [teamId], references: [id])
  ledTeams     Team[]   @relation("TeamLeader")
  joinRequests Team[]   @relation("TeamJoinRequests")
}

model Team {
  id         String   @id @default(uuid())
  teamName   String
  teamCode         String   @unique
  maxSize          Int      @default(4)
  problemStatement Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  leaderId     String
  leader       User     @relation("TeamLeader", fields: [leaderId], references: [id])
  members      User[]   @relation("TeamMembers")
  joinRequests User[]   @relation("TeamJoinRequests")
  registration Registration?
}

model Registration {
  id            String   @id @default(uuid())
  domain        String
  utrNumber     String
  amount        Float    @default(600)
  paymentStatus String   @default("pending")
  status        String   @default("registered")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teamId        String   @unique
  team          Team     @relation(fields: [teamId], references: [id])
}
